#!/bin/sh
PATH=/usr/sbin:/usr/bin:/sbin:/bin

PROG="drcom-auth-watchdog"
LOG_TAG="drcom-auth-watchdog"
LOCKDIR="/var/run/${PROG}.lock"
FETCHER=""
CONFIG_FILE="/etc/config/drcom-auth"

log() {
	logger -t "$LOG_TAG" "$*"
}

rand_v() {
	date +%s | tail -c 5
}

fetch_cmd() {
	if command -v curl >/dev/null 2>&1; then
		echo curl
	elif command -v uclient-fetch >/dev/null 2>&1; then
		echo uclient-fetch
	elif command -v wget >/dev/null 2>&1; then
		echo wget
	else
		return 1
	fi
}

fetch_text() {
	url="$1"
	case "$FETCHER" in
		curl) curl -fsL --max-time "$CHECK_TIMEOUT" "$url" 2>/dev/null ;;
		uclient-fetch) uclient-fetch -qO- --timeout="$CHECK_TIMEOUT" "$url" 2>/dev/null ;;
		wget) wget -qO- --timeout="$CHECK_TIMEOUT" "$url" 2>/dev/null ;;
		*) return 1 ;;
	esac
}

http_code() {
	url="$1"
	case "$FETCHER" in
		curl) curl -fsL -o /dev/null -w "%{http_code}" --max-time "$CHECK_TIMEOUT" "$url" 2>/dev/null ;;
		uclient-fetch)
			out="$(uclient-fetch -S -O /dev/null --timeout="$CHECK_TIMEOUT" "$url" 2>&1)"
			printf "%s" "$out" | sed -n 's/.*HTTP\/[0-9.]* \([0-9][0-9][0-9]\).*/\1/p' | tail -n1
			;;
		wget)
			out="$(wget -S -O /dev/null --timeout="$CHECK_TIMEOUT" "$url" 2>&1)"
			printf "%s" "$out" | sed -n 's/.* \([0-9][0-9][0-9]\) .*/\1/p' | tail -n1
			;;
		*) return 1 ;;
	esac
}

urlencode() {
	# enough for current ascii credentials
	printf '%s' "$1" | sed \
		-e 's/%/%25/g' \
		-e 's/ /%20/g' \
		-e 's/#/%23/g' \
		-e 's/&/%26/g' \
		-e 's/+/%2B/g' \
		-e 's/?/%3F/g' \
		-e 's/@/%40/g'
}

get_if_mac() {
	cat "/sys/class/net/$AUTH_IF/address" 2>/dev/null | tr '[:lower:]' '[:upper:]' | tr -d ':'
}

get_if_ipv4() {
	ip -4 addr show "$AUTH_IF" 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -n1
}

ip_to_int() {
	local ip="$1" a b c d
	IFS=. read -r a b c d <<EOF
$ip
EOF
	echo $((a * 256 * 256 * 256 + b * 256 * 256 + c * 256 + d))
}

load_config() {
	[ -f "$CONFIG_FILE" ] || return 1

	enabled="$(uci -q get drcom-auth.main.enabled)"
	AUTH_IF="$(uci -q get drcom-auth.main.auth_if)"
	WAN_MAC="$(uci -q get drcom-auth.main.wan_mac)"
	GATEWAY_HOST="$(uci -q get drcom-auth.main.gateway_host)"
	LOGIN_URL="$(uci -q get drcom-auth.main.login_url)"
	UNBIND_URL="$(uci -q get drcom-auth.main.unbind_url)"
	USERNAME="$(uci -q get drcom-auth.main.username)"
	PASSWORD="$(uci -q get drcom-auth.main.password)"
	MKKEY="$(uci -q get drcom-auth.main.mkkey)"
	CHECK_HTTP_URL="$(uci -q get drcom-auth.main.check_http_url)"
	CHECK_HTTP_URL_2="$(uci -q get drcom-auth.main.check_http_url_2)"
	HTTP_STRICT_204="$(uci -q get drcom-auth.main.http_strict_204)"
	SUCCESS_INTERVAL="$(uci -q get drcom-auth.main.success_interval)"
	FAIL_CONFIRM_DELAY="$(uci -q get drcom-auth.main.fail_confirm_delay)"
	UNBIND_DELAY="$(uci -q get drcom-auth.main.unbind_delay)"
	LOGIN_DELAY="$(uci -q get drcom-auth.main.login_delay)"
	MAX_BACKOFF="$(uci -q get drcom-auth.main.max_backoff)"
	TERMINAL_TYPE="$(uci -q get drcom-auth.main.terminal_type)"
	JS_VERSION="$(uci -q get drcom-auth.main.js_version)"
	LANG_PRIMARY="$(uci -q get drcom-auth.main.lang_primary)"
	LANG_SECONDARY="$(uci -q get drcom-auth.main.lang_secondary)"
	R1="$(uci -q get drcom-auth.main.r1)"
	R2="$(uci -q get drcom-auth.main.r2)"
	R3="$(uci -q get drcom-auth.main.r3)"
	R6="$(uci -q get drcom-auth.main.r6)"
	PARA="$(uci -q get drcom-auth.main.para)"
	V6IP="$(uci -q get drcom-auth.main.v6ip)"
	UNBIND_FIRST="$(uci -q get drcom-auth.main.unbind_first)"
	LOG_SUCCESS="$(uci -q get drcom-auth.main.log_success)"

	[ -z "$enabled" ] && enabled=1
	[ "$enabled" = "1" ] || return 2

	[ -z "$AUTH_IF" ] && AUTH_IF=eth0
	[ -z "$CHECK_TIMEOUT" ] && CHECK_TIMEOUT=5
	[ -z "$SUCCESS_INTERVAL" ] && SUCCESS_INTERVAL=30
	[ -z "$FAIL_CONFIRM_DELAY" ] && FAIL_CONFIRM_DELAY=2
	[ -z "$UNBIND_DELAY" ] && UNBIND_DELAY=4
	[ -z "$LOGIN_DELAY" ] && LOGIN_DELAY=5
	[ -z "$MAX_BACKOFF" ] && MAX_BACKOFF=60
	[ -z "$TERMINAL_TYPE" ] && TERMINAL_TYPE=1
	[ -z "$JS_VERSION" ] && JS_VERSION=4.1.3
	[ -z "$LANG_PRIMARY" ] && LANG_PRIMARY=zh-cn
	[ -z "$LANG_SECONDARY" ] && LANG_SECONDARY=zh
	[ -z "$R1" ] && R1=0
	[ -z "$R3" ] && R3=0
	[ -z "$R6" ] && R6=0
	[ -z "$PARA" ] && PARA=00
	[ -z "$UNBIND_FIRST" ] && UNBIND_FIRST=1
	[ -z "$HTTP_STRICT_204" ] && HTTP_STRICT_204=1

	[ -n "$WAN_MAC" ] || WAN_MAC="$(get_if_mac)"
	return 0
}

internet_up() {
	[ -n "$CHECK_HTTP_URL" ] || return 1
	code="$(http_code "$CHECK_HTTP_URL")"
	if [ "$HTTP_STRICT_204" = "1" ]; then
		[ "$code" = "204" ] && return 0
	else
		[ -n "$code" ] && [ "$code" -ge 200 ] && [ "$code" -lt 400 ] && return 0
	fi

	if [ -n "$CHECK_HTTP_URL_2" ]; then
		code="$(http_code "$CHECK_HTTP_URL_2")"
		if [ "$HTTP_STRICT_204" = "1" ]; then
			[ "$code" = "204" ] && return 0
		else
			[ -n "$code" ] && [ "$code" -ge 200 ] && [ "$code" -lt 400 ] && return 0
		fi
	fi
	return 1
}

gateway_reachable() {
	ping -c 1 -W 2 "$GATEWAY_HOST" >/dev/null 2>&1
}

build_login_url() {
	v="$(rand_v)"
	printf '%s?callback=dr1003&DDDDD=%s&upass=%s&0MKKey=%s&R1=%s&R2=%s&R3=%s&R6=%s&para=%s&v6ip=%s&terminal_type=%s&lang=%s&jsVersion=%s&v=%s&lang=%s' \
		"$LOGIN_URL" "$(urlencode "$USERNAME")" "$(urlencode "$PASSWORD")" "$MKKEY" "$R1" "$R2" "$R3" "$R6" "$PARA" "$V6IP" "$TERMINAL_TYPE" "$LANG_PRIMARY" "$JS_VERSION" "$v" "$LANG_SECONDARY"
}

build_unbind_url() {
	[ -n "$WAN_MAC" ] || WAN_MAC="$(get_if_mac)"
	WAN_IP="$(get_if_ipv4)"
	WAN_IP_INT="$(ip_to_int "$WAN_IP")"
	v="$(rand_v)"
	printf '%s?callback=dr1004&user_account=%s&wlan_user_mac=%s&wlan_user_ip=%s&jsVersion=%s&v=%s&lang=%s' \
		"$UNBIND_URL" "$(urlencode "$USERNAME")" "$WAN_MAC" "$WAN_IP_INT" "$JS_VERSION" "$v" "$LANG_SECONDARY"
}

do_unbind() {
	url="$(build_unbind_url)"
	fetch_text "$url" >/dev/null
}

do_login() {
	url="$(build_login_url)"
	fetch_text "$url" >/dev/null
}

pow2_delay() {
	n="$1"
	d=5
	i=1
	while [ "$i" -lt "$n" ]; do
		d=$((d * 2))
		[ "$d" -ge "$MAX_BACKOFF" ] && { echo "$MAX_BACKOFF"; return; }
		i=$((i + 1))
	done
	[ "$d" -gt "$MAX_BACKOFF" ] && d="$MAX_BACKOFF"
	echo "$d"
}

run_test() {
	echo "config=$CONFIG_FILE"
	echo "fetcher=$FETCHER"
	echo "auth_if=$AUTH_IF"
	if gateway_reachable; then
		echo "gateway_reachable=yes"
	else
		echo "gateway_reachable=no"
	fi
	echo "wan_mac=${WAN_MAC:-$(get_if_mac)}"
	ip="$(get_if_ipv4)"
	echo "wan_ip=$ip"
	echo "wan_ip_int=$(ip_to_int "$ip")"
	echo "check_http_url=$CHECK_HTTP_URL"
	echo "strict_204=$HTTP_STRICT_204"
}

run_once() {
	if internet_up; then
		[ "$LOG_SUCCESS" = "1" ] && log "网络正常"
		return 0
	fi

	sleep "$FAIL_CONFIRM_DELAY"
	if internet_up; then
		[ "$LOG_SUCCESS" = "1" ] && log "网络正常"
		return 0
	fi

	log "检测到网络异常，开始恢复"

	if [ "$UNBIND_FIRST" = "1" ]; then
		log "执行解绑"
		do_unbind
		sleep "$UNBIND_DELAY"
	fi

	log "执行登录"
	do_login
	sleep "$LOGIN_DELAY"

	if internet_up; then
		log "网络恢复成功"
		return 0
	fi

	log "恢复失败，稍后重试"
	return 1
}

main_loop() {
	fail_count=0
	log "校园网认证服务已启动（接口：$AUTH_IF）"
	while :; do
		if run_once; then
			fail_count=0
			sleep "$SUCCESS_INTERVAL"
		else
			fail_count=$((fail_count + 1))
			delay="$(pow2_delay "$fail_count")"
			log "${delay}秒后重试"
			sleep "$delay"
		fi
	done
}

main() {
	mode="loop"
	while [ $# -gt 0 ]; do
		case "$1" in
			--once) mode="once" ;;
			--test) mode="test" ;;
			--print-urls) mode="print" ;;
			*) ;;
		esac
		shift
	done

	load_config || exit 1
	FETCHER="$(fetch_cmd)" || { echo "no fetcher found" >&2; exit 1; }

	if [ "$mode" = "test" ]; then
		run_test
		exit 0
	fi

	if [ "$mode" = "print" ]; then
		echo "unbind_url=$(build_unbind_url)"
		echo "login_url=$(build_login_url)"
		exit 0
	fi

	if [ "$mode" = "once" ]; then
		run_once
		exit $?
	fi

	mkdir "$LOCKDIR" 2>/dev/null || exit 0
	trap 'rmdir "$LOCKDIR" 2>/dev/null' EXIT INT TERM
	main_loop
}

main "$@"
